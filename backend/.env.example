# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webinar_mvp

# Anthropic / Claude Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Embedding Provider Configuration
# Options: "voyage" | "openai"
EMBEDDING_PROVIDER=voyage

# Embedding Model Configuration
# For voyage-3-large: use EMBEDDING_DIMENSION=1024
# For text-embedding-3-small: use EMBEDDING_DIMENSION=1536
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIMENSION=1024

# API Keys for Embedding Providers
VOYAGE_API_KEY=your_voyage_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Transcription Provider (for future use)
# Options: "whisper" | "deepgram" | "assemblyai" | "json"
TRANSCRIPTION_PROVIDER=json
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Video Base URL (for local development)
VIDEO_BASE_URL=http://localhost:8000/videos
